pipeline {
    agent {
    node {
        label 'AGENT-1'
        
    }
} 

    stages {
        stage('Build') {
            steps {
                echo 'Building..'
            }
        }
        stage('Test') {
            steps {
                echo 'Testing..'
            }
        }
        stage('Deploy') {
            steps {
                echo 'Deploying....'
            }
        }
    }

    post { 
        always { 
            echo 'I will always say Hello again!'
        }
        failure { 
            echo 'This run when pipeline is faled'
        }
        success { 
            echo 'I will always say pipeline is Sucess!'
        }
    }

}